default: sandbox
profiles:
  local-dev:
    name: Local Development
    description: Local MCP servers for development
    mcps:
    - name: Superset MCP
      mcp_url: http://localhost:5008/mcp/
      auth:
        type: bearer
        token: ${SUPERSET_MCP_TOKEN}
  sandbox:
    name: Sandbox Environment
    description: Sandbox servers for integration testing
    mcps:
    - name: Preset Sandbox 66d22a6f
      mcp_url: https://66d22a6f.us1a.app-sdx.preset.io/mcp
      auth:
        type: jwt
        api_url: https://api.app-sdx.preset.io/v1/auth/
        api_token: 9033ca4b-e086-4d3a-8cdc-b81f29fbb513
        api_secret: 9ac699763814aae240fded87ff7dd079a481e65956d00e1081a9155435451ba1
  staging:
    name: Staging Environment
    default: true
    description: Staging servers for integration testing
    mcps:
    - name: Preset Staging a167749f
      mcp_url: https://a167749f.us1a.app-stg.preset.io/mcp
      auth:
        type: jwt
        api_url: https://api.app-stg.preset.io/v1/auth/
        api_token: 6ddb868b-8587-4abb-9a5c-ae272871c6c8
        api_secret: a259c6ece3506e98c6be7bd8e4d13fba8a2389788138fd075d8b7732647573bf
  prod:
    name: Production
    description: Production MCP servers
    mcps:
    - name: Preset prod 2cad
      mcp_url: https://2cad1810.us1a.app.preset.io/mcp
      auth:
        type: jwt
        api_url: https://api.app.preset.io/v1/auth/
        api_token: 78e30c95-0a35-4df5-a191-6fe60c502850
        api_secret: be62e84edebb3a8e8128533f11d73dffc5116c7305fa9915c77d89c7bae18226
global:
  timeout: 30
  rate_limit:
    requests_per_minute: 60
